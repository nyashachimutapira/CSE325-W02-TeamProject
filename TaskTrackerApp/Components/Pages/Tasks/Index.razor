@page "/tasks"
@rendermode InteractiveServer
@using TaskTrackerApp.Data
@using TaskTrackerApp.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject TaskService TaskService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager NavigationManager
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>My Tasks</PageTitle>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #2c3e50;">My Tasks</h2>
        <a href="/tasks/create" class="btn btn-primary shadow-sm" style="border-radius: 20px; padding: 0.5rem 1.5rem;">
            <i class="bi bi-plus-lg"></i> + New Task
        </a>
    </div>

    @if (tasks == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!tasks.Any())
    {
        <div class="alert alert-info text-center shadow-sm" style="border-radius: 15px;">
            You have no tasks yet. Get started by clicking the "New Task" button!
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var task in tasks)
            {
                <div class="col">
                    <div class="card h-100 shadow border-0" style="border-radius: 20px; overflow: hidden; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                        <!-- Decorator line based on status -->
                        <div style="height: 5px; background: @(task.IsCompleted ? "#28a745" : "#007bff");"></div>
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@task.Title</h5>
                            <h6 class="card-subtitle mb-2 text-muted" style="font-size: 0.9rem;">
                                @if (task.DueDate.HasValue)
                                {
                                    <span class="@(task.DueDate < DateTime.UtcNow && !task.IsCompleted ? "text-danger" : "")">
                                        Due: @task.DueDate.Value.ToString("MMM dd, yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span>No Due Date</span>
                                }
                            </h6>
                            <p class="card-text mt-3" style="font-size: 0.95rem; color: #555;">@task.Description</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center pb-3">
                            <div>
                                @if (task.IsCompleted)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary rounded-pill px-3 py-2 shadow-sm">Pending</span>
                                }
                            </div>
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-success mx-1" style="border-radius: 10px;" @onclick="() => ToggleStatus(task)" title="Toggle Status">
                                    ✓
                                </button>
                                <a href="@($"/tasks/edit/{task.Id}")" class="btn btn-sm btn-outline-secondary mx-1" style="border-radius: 10px;" title="Edit">
                                    ✎
                                </a>
                                <button class="btn btn-sm btn-outline-danger mx-1" style="border-radius: 10px;" @onclick="() => DeleteTask(task.Id)" title="Delete">
                                    ✖
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TaskItem>? tasks;
    private string userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

        if (!string.IsNullOrEmpty(userId))
        {
            await LoadTasks();
        }
    }

    private async Task LoadTasks()
    {
        tasks = await TaskService.GetTasksAsync(userId);
    }

    private async Task ToggleStatus(TaskItem task)
    {
        task.IsCompleted = !task.IsCompleted;
        await TaskService.UpdateTaskAsync(task);
        await LoadTasks();
    }

    private async Task DeleteTask(int id)
    {
        await TaskService.DeleteTaskAsync(id, userId);
        await LoadTasks();
    }
}
